# ── mc-api-server environment variables ─────────────────────────────────
# Copy to .env (git-ignored). Env vars override values in api-server-config.json.

# API key clients must send in the x-api-key header
MC_API_KEY=replace-with-a-long-random-secret

# HTTP port (default: value in config)
# MC_PORT=3000

# Listen address (default 0.0.0.0). MC_ALLOW_NO_AUTH=true forces 127.0.0.1.
# MC_BIND_HOST=0.0.0.0

# Path to api-server-config.json (default: repo root)
# CONFIG_FILE=/etc/mc-api-server/api-server-config.json

# Per-instance RCON password override (replace SURVIVAL with your instance ID)
# RCON_PASSWORD_SURVIVAL=your-rcon-password

# Trust X-Forwarded-For for client IPs (rate limiting / auth-fail lockout).
# ONLY enable when the wrapper runs behind a reverse proxy that SETS this
# header itself — otherwise clients can spoof their IP to the limiters.
# Without it, behind a proxy, all clients share the proxy's IP: one
# attacker's 20 failed keys lock everyone out. Default: false.
# MC_TRUST_PROXY=true

# Max concurrent SSE log-stream clients per instance (default 50);
# requests beyond the cap get 503.
# MC_SSE_MAX_CLIENTS=50

# Keyless loopback-only dev mode — never in production
# MC_ALLOW_NO_AUTH=true

# Debug logging
# MC_DEBUG=true
