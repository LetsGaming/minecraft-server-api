{
  "name": "mc-api-server",
  "version": "2.0.0",
  "description": "Lightweight HTTP wrapper for managing a Minecraft server instance. Exposes server operations over a REST API secured with an API key.",
  "type": "commonjs",
  "main": "index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node index.js",
    "test": "node --test tests/parseVars.test.js tests/operations.test.js tests/rcon.test.js",
    "update": "node scripts/update-deps.mjs"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2"
  },
  "devDependencies": {
    "@types/node": ">=18"
  }
}
